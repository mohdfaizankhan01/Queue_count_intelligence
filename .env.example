# Copy this file to .env and adjust as needed.
# docker-compose and run_full_pipeline.py both read these variables.

# Optical encoding strength: 0.0 = no encoding (no privacy), 1.0 = maximum encoding
ENCODING_STRENGTH=0.4

# Number of active voting booths per station (used by ServiceRateModel)
N_BOOTHS_DEFAULT=3

# Crowd counter to use: hog | csrnet | density
COUNTER_TYPE=hog

# Mean time a voter spends in the booth (seconds)
AVG_SERVICE_TIME_SEC=120

# SQLite database path (relative to working directory when running locally)
DB_PATH=results/history.db

# Path to privacy evaluation results CSV (generated by run_privacy_eval.py)
PRIVACY_RESULTS_CSV=results/privacy_results.csv
